  "display": {
    "formats": {
      "deposit()": {
        "intent": "Deposit ETH into your vault balance",
        "fields": [
          {
            "path": "$.value",
            "label": "Amount",
            "format": "amount"
          }
        ]
      },
      "withdraw(address to, uint256 amount)": {
        "intent": "Withdraw ETH from your vault balance",
        "fields": [
          {
            "path": "to",
            "label": "Recipient",
            "format": "addressName",
            "params": {
              "types": [
                "wallet",
                "eoa",
                "contract"
              ]
            }
          },
          {
            "path": "amount",
            "label": "Amount",
            "format": "amount"
          }
        ]
      },
      "withdrawWithPermit(address owner, address to, uint256 amount, uint256 deadline, uint8 v, bytes32 r, bytes32 s)": {
        "intent": "Withdraw ETH from an account's vault balance using a permit",
        "fields": [
          {
            "path": "owner",
            "label": "Owner",
            "format": "addressName",
            "params": {
              "types": [
                "wallet",
                "eoa"
              ]
            }
          },
          {
            "path": "to",
            "label": "Recipient",
            "format": "addressName",
            "params": {
              "types": [
                "wallet",
                "eoa",
                "contract"
              ]
            }
          },
          {
            "path": "amount",
            "label": "Amount",
            "format": "amount"
          },
          {
            "path": "deadline",
            "label": "Expires On",
            "format": "date",
            "params": {
              "encoding": "timestamp"
            }
          }
        ]
      }

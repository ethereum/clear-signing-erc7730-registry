      "approve(address operator,uint256 tokenId)": {
        "intent": "Approve artwork transfer",
        "interpolatedIntent": "Allow {operator} to transfer token {tokenId}",
        "fields": [
          {
            "path": "operator",
            "label": "Operator",
            "format": "addressName",
            "params": {
              "types": [
                "eoa",
                "contract"
              ]
            }
          },
          {
            "path": "tokenId",
            "label": "Artwork",
            "format": "nftName",
            "params": {
              "collectionPath": "@.to"
            }
          }
        ]
      },
      "setApprovalForAll(address operator,bool approved)": {
        "intent": "Set operator approval",
        "interpolatedIntent": "{approved} all tokens for {operator}",

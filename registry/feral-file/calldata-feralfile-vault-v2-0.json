{
  "$schema": "../../specs/erc7730-v2.schema.json",
  "context": {
    "$id": "feralfile-vaultV2",
    "contract": {
      "deployments": [
        {
          "chainId": 1,
          "address": "0xcBFaf4BDE69C9b37835761E5228f9fe9E25b452f"
        }
      ]
    }
  },
  "metadata": {
    "owner": "Feral File",
    "info": {
      "url": "https://feralfile.com"
    },
    "contractName": "Feral File Vault V2"
  },
  "display": {
    "formats": {
      "payForSaleV2(bytes32 r_,bytes32 s_,uint8 v_,(uint256 price,uint256 cost,uint256 expiryTime,address destination,uint256 nonce,uint256 seriesID,uint16 quantity,(address recipient,uint256 bps)[] revenueShares,bool payByVaultContract) saleData_)": {
        "intent": "Pay for bulk artwork sale",
        "fields": [
          {
            "path": "saleData_.price",
            "label": "Price",
            "format": "amount"
          },
          {
            "path": "saleData_.cost",
            "label": "Platform cost",
            "format": "amount"
          },
          {
            "path": "saleData_.destination",
            "label": "Recipient",
            "format": "addressName",
            "params": {
              "types": [
                "eoa",
                "contract"
              ]
            }
          },
          {
            "path": "saleData_.seriesID",
            "label": "Series ID",
            "format": "raw"
          },
          {
            "path": "saleData_.quantity",
            "label": "Quantity",
            "format": "raw"
          },
          {
            "path": "saleData_.revenueShares.[].recipient",
            "label": "Revenue recipient",
            "format": "addressName",
            "params": {
              "types": [
                "eoa",
                "contract"
              ]
            }
          },
          {
            "path": "saleData_.revenueShares.[].bps",
            "label": "Revenue share (basis points)",
            "format": "raw"
          }
        ]
      },
      "withdrawFund(uint256 weiAmount)": {
        "intent": "Withdraw vault funds",
        "fields": [
          {
            "path": "weiAmount",
            "label": "Amount",
            "format": "amount"
          }
        ]
      }
    }
  }
}

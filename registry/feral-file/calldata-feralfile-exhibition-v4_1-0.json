          {
            "path": "operator",
            "label": "Operator",
            "format": "addressName",
            "params": {
              "types": [
                "eoa",
                "contract"
              ]
            }
          },
          {
            "path": "approved",
            "label": "Approved",
            "format": "raw"
          }
        ]
      },
      "burnArtworks(uint256[] tokenIds)": {
        "intent": "Burn artworks",
        "interpolatedIntent": "Permanently destroy selected artworks",
        "fields": [
          {
            "path": "tokenIds.[]",
            "label": "Artworks",
            "format": "nftName",
            "params": {
              "collectionPath": "@.to"
            },
            "separator": ", "
          }
        ]
      },
      "buyArtworks(bytes32 r_,bytes32 s_,uint8 v_,(uint256 price,uint256 cost,uint256 expiryTime,address destination,uint256[] tokenIds,(address recipient,uint256 bps)[][] revenueShares,bool payByVaultContract) saleData_)": {
        "intent": "Purchase artworks",
        "interpolatedIntent": "Buy artworks for {saleData_.destination}",
        "fields": [
          {
            "path": "saleData_.price",
            "label": "Price",
            "format": "amount"
          },
          {
            "path": "saleData_.cost",
            "label": "Platform cost",
            "format": "amount"
          },
          {
            "path": "saleData_.destination",
            "label": "Recipient",
            "format": "addressName",
            "params": {
              "types": [
                "eoa",
                "contract"
              ]
            }
          },
          {
            "path": "saleData_.tokenIds.[]",
            "label": "Artworks",
            "format": "nftName",
            "params": {
              "collectionPath": "@.to"
            },
            "separator": ", "
          },
          {
            "path": "saleData_.expiryTime",
            "label": "Offer expires",
            "format": "date",
            "params": {
              "encoding": "timestamp"
            }
          },
          {
            "path": "saleData_.payByVaultContract",
            "label": "Pay via vault",
            "format": "raw"
          },
          {
            "path": "saleData_.revenueShares.[].[].recipient",
            "label": "Revenue recipient",
            "format": "addressName",
            "params": {
              "types": [
                "eoa",
                "contract"
              ]
            }
          },
          {
            "path": "saleData_.revenueShares.[].[].bps",
            "label": "Revenue share (basis points)",
            "format": "raw"
          }
        ]
      },

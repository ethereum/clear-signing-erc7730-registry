        "intent": "Start artwork sale",
        "fields": []
      },
      "resumeSale()": {
        "intent": "Resume artwork sale",
        "fields": []
      },
      "pauseSale()": {
        "intent": "Pause artwork sale",
        "fields": []
      },
      "stopSaleAndBurn()": {
        "intent": "Stop sale and burn unsold artworks",

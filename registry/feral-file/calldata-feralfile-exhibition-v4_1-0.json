      "transferFrom(address from,address to,uint256 tokenId)": {
        "intent": "Transfer artwork",
        "interpolatedIntent": "Transfer token {tokenId} from {from} to {to}",
        "fields": [
          {
            "path": "from",
            "label": "From",
            "format": "addressName",
            "params": {
              "types": [
                "eoa",
                "contract"
              ]
            }
          },
          {
            "path": "to",
            "label": "To",
            "format": "addressName",
            "params": {
              "types": [
                "eoa",
                "contract"
              ]
            }
          },
          {
            "path": "tokenId",
            "label": "Artwork",
            "format": "nftName",
            "params": {
              "collectionPath": "@.to"
            }
          }
        ]
      },
      "safeTransferFrom(address from,address to,uint256 tokenId)": {
        "intent": "Transfer artwork",

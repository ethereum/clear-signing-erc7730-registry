{
  "$schema": "../../specs/erc7730-v2.schema.json",
  "context": {
    "$id": "NEXUS Protocol POC",
    "contract": {
      "deployments": [
        { "chainId": 84532, "address": "0x471796C1644d87f30AD81D36f6d4A56f0e270c23" }
      ]
    }
  },
  "metadata": {
    "owner": "NEXUS Protocol (avp9)",
    "info": { "url": "https://nexus-art.org", "deploymentDate": "2026-05-30T15:03:16Z" }
  },
  "display": {
    "formats": {
      "placeBid(uint256 tokenId)": {
        "intent": "Place bid on artwork",
        "fields": [
          { "path": "tokenId", "label": "Artwork (tokenId)", "format": "raw" },
          { "path": "@.value", "label": "Bid amount", "format": "amount" }
        ]
      },
      "settleAuction(uint256 tokenId)": {
        "intent": "Settle auction",
        "fields": [
          { "path": "tokenId", "label": "Artwork (tokenId)", "format": "raw" }
        ]
      },
      "startAuction(uint256 tokenId,uint256 reservePrice,uint256 duration)": {
        "intent": "Start auction",
        "fields": [
          { "path": "tokenId", "label": "Artwork (tokenId)", "format": "raw" },
          { "path": "reservePrice", "label": "Reserve price", "format": "amount" },
          { "path": "duration", "label": "Duration (seconds)", "format": "raw" }
        ]
      },
      "setAgentWhitelist(address agent,bool allowed)": {
        "intent": "Whitelist bidding agent",
        "fields": [
          { "path": "agent", "label": "Agent address", "format": "addressName", "params": { "types": ["eoa"], "sources": ["local", "ens"] } },
          { "path": "allowed", "label": "Allowed", "format": "raw" }
        ]
      },
      "mintWork(address creator,string uri,uint96 royaltyBps)": {
        "intent": "Mint artwork",
        "fields": [
          { "path": "creator", "label": "Creator (royalty)", "format": "addressName", "params": { "types": ["eoa"], "sources": ["local", "ens"] } },
          { "path": "uri", "label": "Metadata URI", "format": "raw" },
          { "path": "royaltyBps", "label": "Royalty (bps)", "format": "raw" }
        ]
      },
      "setCuratorRecipient(address newCurator)": {
        "intent": "Set curator wallet",
        "fields": [
          { "path": "newCurator", "label": "New curator address", "format": "addressName", "params": { "types": ["eoa"], "sources": ["local", "ens"] } }
        ]
      },
      "setPlatformRecipient(address newPlatform)": {
        "intent": "Set platform wallet",
        "fields": [
          { "path": "newPlatform", "label": "New platform address", "format": "addressName", "params": { "types": ["eoa"], "sources": ["local", "ens"] } }
        ]
      },
      "transferOwnership(address newOwner)": {
        "intent": "Transfer ownership",
        "fields": [
          { "path": "newOwner", "label": "New owner address", "format": "addressName", "params": { "types": ["eoa"], "sources": ["local", "ens"] } }
        ]
      },
      "renounceOwnership()": {
        "intent": "Renounce ownership FOREVER",
        "fields": []
      },
      "setApprovalForAll(address operator,bool approved)": {
        "intent": "Approve ALL artworks",
        "fields": [
          { "path": "operator", "label": "Operator address", "format": "addressName", "params": { "types": ["contract"], "sources": ["local", "ens"] } },
          { "path": "approved", "label": "Access granted", "format": "raw" }
        ]
      },
      "approve(address to,uint256 tokenId)": {
        "intent": "Approve one artwork",
        "fields": [
          { "path": "to", "label": "Operator address", "format": "addressName", "params": { "types": ["contract"], "sources": ["local", "ens"] } },
          { "path": "tokenId", "label": "Artwork (tokenId)", "format": "raw" }
        ]
      },
      "transferFrom(address from,address to,uint256 tokenId)": {
        "intent": "Transfer artwork",
        "fields": [
          { "path": "from", "label": "From", "format": "addressName", "params": { "types": ["eoa"], "sources": ["local", "ens"] } },
          { "path": "to", "label": "To", "format": "addressName", "params": { "types": ["eoa"], "sources": ["local", "ens"] } },
          { "path": "tokenId", "label": "Artwork (tokenId)", "format": "raw" }
        ]
      },
      "safeTransferFrom(address from,address to,uint256 tokenId)": {
        "intent": "Transfer artwork",
        "fields": [
          { "path": "from", "label": "From", "format": "addressName", "params": { "types": ["eoa"], "sources": ["local", "ens"] } },
          { "path": "to", "label": "To", "format": "addressName", "params": { "types": ["eoa"], "sources": ["local", "ens"] } },
          { "path": "tokenId", "label": "Artwork (tokenId)", "format": "raw" }
        ]
      },
      "safeTransferFrom(address from,address to,uint256 tokenId,bytes data)": {
        "intent": "Transfer artwork",
        "fields": [
          { "path": "from", "label": "From", "format": "addressName", "params": { "types": ["eoa"], "sources": ["local", "ens"] } },
          { "path": "to", "label": "To", "format": "addressName", "params": { "types": ["eoa"], "sources": ["local", "ens"] } },
          { "path": "tokenId", "label": "Artwork (tokenId)", "format": "raw" },
          { "path": "data", "label": "Extra data", "format": "raw" }
        ]
      }
    }
  }
}

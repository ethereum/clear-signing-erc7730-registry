        "intent": "Deposit token",
        "interpolatedIntent": "Deposit {_value}",
        "fields": [
          {
            "path": "_value",
            "label": "Amount",
            "format": "tokenAmount",
            "params": {
              "tokenPath": "_asset"
            },
            "visible": "always"
          },
          {
            "path": "_asset",
            "label": "Asset",
            "format": "raw",
            "visible": "optional"
          },
          {
            "path": "_precommitment",
            "label": "Precommitment",
            "visible": "never"
          }
        ]
      }
    }
  }

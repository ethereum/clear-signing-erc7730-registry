{
  "$schema": "../../specs/erc7730-v2.schema.json",
  "context": {
    "contract": {
      "deployments": [
        { "chainId": 8453, "address": "0x84255D39B5C5132d75Db4F80cd8549b9F9d74aE7" }
      ]
    }
  },
  "metadata": {
    "owner": "Bureaucrawl",
    "contractName": "BureaucrawlRuns",
    "info": {
      "url": "https://bureaucrawl.com",
      "deploymentDate": "2026-05-03T13:25:09Z"
    }
  },
  "display": {
    "formats": {
      "submitRun(uint256 score, uint256 level, bytes32 runId, uint256 nonce, bytes sig)": {
        "$id": "submitRun",
        "intent": "Mint Bureaucrawl run",
        "interpolatedIntent": "Mint run, score {#.score}",
        "fields": [
          { "label": "Score", "format": "raw", "path": "#.score" },
          { "label": "Level", "format": "raw", "path": "#.level" },
          { "label": "Run ID", "format": "raw", "path": "#.runId" },
          { "label": "Nonce", "format": "raw", "path": "#.nonce", "visible": "never" },
          { "label": "Signature", "format": "raw", "path": "#.sig", "visible": "never" }
        ]
      },
      "setBaseURI(string newBaseURI)": {
        "$id": "setBaseURI",
        "intent": "Update NFT metadata URL",
        "fields": [
          { "label": "New base URI", "format": "raw", "path": "#.newBaseURI" }
        ]
      },
      "setSigner(address newSigner)": {
        "$id": "setSigner",
        "intent": "Rotate score signer key",
        "fields": [
          { "label": "New signer", "format": "addressName", "params": { "types": ["eoa"] }, "path": "#.newSigner" }
        ]
      },
      "transferOwnership(address newOwner)": {
        "$id": "transferOwnership",
        "intent": "Propose ownership transfer",
        "fields": [
          { "label": "New owner", "format": "addressName", "params": { "types": ["eoa", "wallet"] }, "path": "#.newOwner" }
        ]
      },
      "acceptOwnership()": {
        "$id": "acceptOwnership",
        "intent": "Accept ownership transfer",
        "fields": []
      },
      "renounceOwnership()": {
        "$id": "renounceOwnership",
        "intent": "Renounce contract ownership",
        "fields": []
      }
    }
  }
}

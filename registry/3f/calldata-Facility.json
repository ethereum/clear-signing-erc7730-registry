{
  "$schema": "../../specs/erc7730-v2.schema.json",
  "context": {
    "$id": "3F Facility",
    "contract": {
      "abi": [
        {
          "type": "function",
          "name": "deposit",
          "stateMutability": "nonpayable",
          "inputs": [{ "name": "id", "type": "uint256" }, { "name": "amount", "type": "uint256" }],
          "outputs": []
        },
        {
          "type": "function",
          "name": "withdraw",
          "stateMutability": "nonpayable",
          "inputs": [
            { "name": "id", "type": "uint256" },
            { "name": "from", "type": "address" },
            { "name": "receiver", "type": "address" },
            { "name": "amount", "type": "uint256" }
          ],
          "outputs": []
        },
        {
          "type": "function",
          "name": "claim",
          "stateMutability": "nonpayable",
          "inputs": [
            { "name": "id", "type": "uint256" },
            { "name": "from", "type": "address" },
            { "name": "receiver", "type": "address" },
            { "name": "shares", "type": "uint256" }
          ],
          "outputs": []
        }
      ],
      "deployments": [{ "chainId": 1, "address": "0x4e013ca8ff612a58f53c822904cdd0ec538a4a4f" }]
    }
  },
  "metadata": { "owner": "3F", "info": { "url": "https://3f.xyz" }, "contractName": "Facility" },
  "display": {
    "formats": {
      "deposit(uint256 id, uint256 amount)": {
        "intent": "Deposit into 3F vault",
        "fields": [
          { "label": "Intent ID", "format": "raw", "path": "#.id", "visible": "always" },
          { "label": "Amount", "format": "raw", "path": "#.amount", "visible": "always" }
        ]
      },
      "withdraw(uint256 id, address from, address receiver, uint256 amount)": {
        "intent": "Withdraw from 3F vault",
        "fields": [
          { "label": "Intent ID", "format": "raw", "path": "#.id", "visible": "always" },
          {
            "label": "From",
            "format": "addressName",
            "params": { "types": ["eoa", "wallet", "contract"], "sources": ["local", "ens"] },
            "path": "#.from",
            "visible": "always"
          },
          {
            "label": "Receiver",
            "format": "addressName",
            "params": { "types": ["eoa", "wallet", "contract"], "sources": ["local", "ens"] },
            "path": "#.receiver",
            "visible": "always"
          },
          { "label": "Amount", "format": "raw", "path": "#.amount", "visible": "always" }
        ]
      },
      "claim(uint256 id, address from, address receiver, uint256 shares)": {
        "intent": "Claim from 3F vault",
        "fields": [
          { "label": "Intent ID", "format": "raw", "path": "#.id", "visible": "always" },
          {
            "label": "From",
            "format": "addressName",
            "params": { "types": ["eoa", "wallet", "contract"], "sources": ["local", "ens"] },
            "path": "#.from",
            "visible": "always"
          },
          {
            "label": "Receiver",
            "format": "addressName",
            "params": { "types": ["eoa", "wallet", "contract"], "sources": ["local", "ens"] },
            "path": "#.receiver",
            "visible": "always"
          },
          { "label": "Shares", "format": "raw", "path": "#.shares", "visible": "always" }
        ]
      }
    }
  }
}

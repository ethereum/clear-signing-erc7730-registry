{
  "$schema": "../../specs/erc7730-v2.schema.json",
  "context": {
    "contract": {
      "deployments": [
        {
          "chainId": 1,
          "address": "0x5721cbbd64fc7ae3ef44a0a3f9a790a9264cf9bf"
        },
        {
          "chainId": 1,
          "address": "0x9502b7c397e9aa22fe9db7ef7daf21cd2aebe56b"
        },
        {
          "chainId": 1,
          "address": "0xd442e41019b7f5c4dd78f50dc03726c446148695"
        }
      ]
    }
  },
  "metadata": {
    "owner": "Liquity",
    "info": {
      "url": "https://www.liquity.org"
    },
    "constants": {
      "boldToken": "0x6440f144b7e50d6a8439336510312d2f54beb01d"
    },
    "enums": {
      "yesNo": {
        "0": "No",
        "1": "Yes"
      }
    }
  },
  "display": {
    "formats": {
      "provideToSP(uint256 _topUp, bool _doClaim)": {
        "intent": "Deposit to Earn",
        "interpolatedIntent": "Deposit {_topUp}",
        "fields": [
          {
            "path": "#._topUp",
            "label": "Deposit BOLD",
            "format": "tokenAmount",
            "params": {
              "token": "$.metadata.constants.boldToken"
            }
          },
          {
            "path": "#._doClaim",
            "label": "Claim rewards",
            "format": "enum",
            "params": {
              "$ref": "$.metadata.enums.yesNo"
            }
          }
        ]
      },
      "withdrawFromSP(uint256 _amount, bool _doClaim)": {
        "intent": "Withdraw from Earn",
        "interpolatedIntent": "Withdraw {_amount}",
        "fields": [
          {
            "path": "#._amount",
            "label": "Withdraw BOLD",
            "format": "tokenAmount",
            "params": {
              "token": "$.metadata.constants.boldToken"
            }
          },
          {
            "path": "#._doClaim",
            "label": "Claim rewards",
            "format": "enum",
            "params": {
              "$ref": "$.metadata.enums.yesNo"
            }
          }
        ]
      },
      "claimAllCollGains()": {
        "intent": "Claim collateral gains",
        "fields": []
      }
    }
  }
}
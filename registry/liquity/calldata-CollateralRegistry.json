{
  "$schema": "../../specs/erc7730-v2.schema.json",
  "context": {
    "contract": {
      "deployments": [
        {
          "chainId": 1,
          "address": "0xf949982b91c8c61e952b3ba942cbbfaef5386684"
        }
      ]
    }
  },
  "metadata": {
    "owner": "Liquity",
    "info": {
      "url": "https://www.liquity.org"
    },
    "constants": {
      "boldToken": "0x6440f144b7e50d6a8439336510312d2f54beb01d"
    }
  },
  "display": {
    "formats": {
      "redeemCollateral(uint256 _boldAmount, uint256 _maxIterationsPerCollateral, uint256 _maxFeePercentage)": {
        "intent": "Redeem BOLD",
        "interpolatedIntent": "Redeem {_boldAmount}",
        "fields": [
          {
            "path": "#._boldAmount",
            "label": "Redeem BOLD",
            "format": "tokenAmount",
            "params": {
              "token": "$.metadata.constants.boldToken"
            }
          },
          {
            "path": "#._maxFeePercentage",
            "label": "Max fee",
            "format": "unit",
            "params": {
              "base": "%",
              "decimals": 16
            }
          },
          {
            "path": "#._maxIterationsPerCollateral",
            "label": "",
            "format": "raw",
            "visible": "never"
          }
        ]
      }
    }
  }
}
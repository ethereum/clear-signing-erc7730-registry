{
  "$schema": "../../specs/erc7730-v2.schema.json",
  "context": {
    "$id": "rocketDAONodeTrustedProposals",
    "contract": {
      "deployments": [
        { "chainId": 1, "address": "0xb0ec3F657ef43A615aB480FA8D5A53BF2c2f05d5" },
        { "chainId": 560048, "address": "0x2d3142a05bDD16a3223B585a7A48132867dA6480" }
      ]
    }
  },
  "metadata": {
    "owner": "Rocket Pool",
    "info": { "url": "https://rocketpool.net" },
    "contractName": "rocketDAONodeTrustedProposals"
  },
  "display": {
    "formats": {
      "propose(string _proposalMessage, bytes _payload)": {
        "intent": "Submit oracle DAO proposal",
        "fields": [
          { "label": "Message", "format": "raw", "path": "#._proposalMessage", "visible": "always" },
          { "label": "Payload", "path": "#._payload", "visible": "never" }
        ]
      },
      "vote(uint256 _proposalID, bool _support)": {
        "intent": "Vote on oracle DAO proposal",
        "fields": [
          { "label": "Proposal ID", "format": "raw", "path": "#._proposalID", "visible": "always" },
          { "label": "Support", "format": "raw", "path": "#._support", "visible": "always" }
        ]
      },
      "cancel(uint256 _proposalID)": {
        "intent": "Cancel oracle DAO proposal",
        "fields": [{ "label": "Proposal ID", "format": "raw", "path": "#._proposalID", "visible": "always" }]
      },
      "execute(uint256 _proposalID)": {
        "intent": "Execute oracle DAO proposal",
        "fields": [{ "label": "Proposal ID", "format": "raw", "path": "#._proposalID", "visible": "always" }]
      }
    }
  }
}

{
  "$schema": "../../specs/erc7730-v2.schema.json",
  "context": {
    "$id": "rocketNodeStaking",
    "contract": {
      "deployments": [
        { "chainId": 1, "address": "0xedFc7DCaE43fF954577a2875a9D805874490eE3E" },
        { "chainId": 560048, "address": "0x5520aBac3C9103216D3b23FfEf3AC1aa0CEB24CA" }
      ]
    }
  },
  "metadata": {
    "owner": "Rocket Pool",
    "info": { "url": "https://rocketpool.net" },
    "constants": { "RPLaddress": "0xD33526068D116cE69F19A9ee46F0bd304F21A51f" },
    "contractName": "rocketNodeStaking"
  },
  "display": {
    "formats": {
      "stakeRPL(uint256 _amount)": {
        "intent": "Stake RPL",
        "interpolatedIntent": "Stake {_amount}",
        "fields": [
          {
            "label": "Amount",
            "format": "tokenAmount",
            "path": "#._amount",
            "params": { "token": "$.metadata.constants.RPLaddress" },
            "visible": "always"
          }
        ]
      },
      "stakeRPLFor(address _nodeAddress, uint256 _amount)": {
        "intent": "Stake RPL for node",
        "fields": [
          {
            "label": "Node",
            "format": "addressName",
            "params": { "types": ["eoa", "wallet"], "sources": ["local", "ens"] },
            "path": "#._nodeAddress",
            "visible": "always"
          },
          {
            "label": "Amount",
            "format": "tokenAmount",
            "path": "#._amount",
            "params": { "token": "$.metadata.constants.RPLaddress" },
            "visible": "always"
          }
        ]
      },
      "unstakeRPL(uint256 _amount)": {
        "intent": "Unstake RPL",
        "interpolatedIntent": "Unstake {_amount}",
        "fields": [
          {
            "label": "Amount",
            "format": "tokenAmount",
            "path": "#._amount",
            "params": { "token": "$.metadata.constants.RPLaddress" },
            "visible": "always"
          }
        ]
      },
      "unstakeRPLFor(address _nodeAddress, uint256 _amount)": {
        "intent": "Unstake RPL for node",
        "fields": [
          {
            "label": "Node",
            "format": "addressName",
            "params": { "types": ["eoa", "wallet"], "sources": ["local", "ens"] },
            "path": "#._nodeAddress",
            "visible": "always"
          },
          {
            "label": "Amount",
            "format": "tokenAmount",
            "path": "#._amount",
            "params": { "token": "$.metadata.constants.RPLaddress" },
            "visible": "always"
          }
        ]
      },
      "unstakeLegacyRPL(uint256 _amount)": {
        "intent": "Unstake legacy RPL",
        "fields": [
          {
            "label": "Amount",
            "format": "tokenAmount",
            "path": "#._amount",
            "params": { "token": "$.metadata.constants.RPLaddress" },
            "visible": "always"
          }
        ]
      },
      "unstakeLegacyRPLFor(address _nodeAddress, uint256 _amount)": {
        "intent": "Unstake legacy RPL for node",
        "fields": [
          {
            "label": "Node",
            "format": "addressName",
            "params": { "types": ["eoa", "wallet"], "sources": ["local", "ens"] },
            "path": "#._nodeAddress",
            "visible": "always"

          {
            "label": "Amount",
            "format": "tokenAmount",
            "path": "#._amount",
            "params": { "token": "$.metadata.constants.RPLaddress" },
            "visible": "always"
          }
        ]
      },
      "withdrawRPL()": { "intent": "Withdraw staked RPL", "fields": [] },
      "withdrawRPLFor(address _nodeAddress)": {
        "intent": "Withdraw staked RPL for node",
        "fields": [
          {
            "label": "Node",
            "format": "addressName",
            "params": { "types": ["eoa", "wallet"], "sources": ["local", "ens"] },
            "path": "#._nodeAddress",
            "visible": "always"
          }
        ]
      },
      "setStakeRPLForAllowed(address _caller, bool _allowed)": {
        "intent": "Set RPL staking permission",
        "fields": [
          {
            "label": "Caller",
            "format": "addressName",
            "params": { "types": ["eoa", "wallet", "contract"], "sources": ["local", "ens"] },
            "path": "#._caller",
            "visible": "always"
          },
          { "label": "Allowed", "format": "raw", "path": "#._allowed", "visible": "always" }
        ]
      },

{
  "$schema": "../../specs/erc7730-v2.schema.json",
  "context": {
    "$id": "rocketAuctionManager",
    "contract": {
      "deployments": [
        { "chainId": 1, "address": "0x1a2F00D187C9388fDa3Bf2dc46a6b4740849EcCE" },
        { "chainId": 560048, "address": "0x84D11B65E026F7aA08F5497dd3593fb083410B71" }
      ]
    }
  },
  "metadata": {
    "owner": "Rocket Pool",
    "info": { "url": "https://rocketpool.net", "legalName": "Rocket Pool" },
    "contractName": "rocketAuctionManager"
  },
  "display": {
    "formats": {
      "createLot()": { "intent": "Create RPL auction lot", "fields": [] },
      "placeBid(uint256 _lotIndex)": {
        "intent": "Bid on RPL auction lot",
        "interpolatedIntent": "Bid {@.value} ETH",
        "fields": [
          { "label": "ETH bid", "format": "amount", "path": "@.value", "visible": "always" },
          { "label": "Lot index", "format": "raw", "path": "#._lotIndex", "visible": "always" }
        ]
      },
      "claimBid(uint256 _lotIndex)": {
        "intent": "Claim RPL from auction lot",
        "fields": [{ "label": "Lot index", "format": "raw", "path": "#._lotIndex", "visible": "always" }]
      },
      "recoverUnclaimedRPL(uint256 _lotIndex)": {
        "intent": "Recover unclaimed RPL",
        "fields": [{ "label": "Lot index", "format": "raw", "path": "#._lotIndex", "visible": "always" }]
      }
    }
  }
}

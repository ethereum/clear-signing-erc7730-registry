{
  "$schema": "../../specs/erc7730-v2.schema.json",
  "context": {
    "$id": "rocketNetworkVoting",
    "contract": {
      "deployments": [
        { "chainId": 1, "address": "0x994A9C49230FEC0c127B8F42D6c5288F02610AeD" },
        { "chainId": 560048, "address": "0xd29b82cC5a06311921db10F156896E3588858169" }
      ]
    }
  },
  "metadata": {
    "owner": "Rocket Pool",
    "info": { "url": "https://rocketpool.net" },
    "contractName": "rocketNetworkVoting"
  },
  "display": {
    "formats": {
      "setDelegate(address _newDelegate)": {
        "intent": "Set voting delegate",
        "interpolatedIntent": "Delegate to {_newDelegate}",

{
  "$schema": "../../specs/erc7730-v2.schema.json",
  "context": {
    "$id": "rocketDAOSecurityActions",
    "contract": {
      "deployments": [
        { "chainId": 1, "address": "0xeaa442dF4Bb5394c66C8024eFb4979bEc89Eb59a" },
        { "chainId": 560048, "address": "0x560656C8947564363497E9C78A8BDEff8d3EFF33" }
      ]
    }
  },
  "metadata": {
    "owner": "Rocket Pool",
    "info": { "url": "https://rocketpool.net" },
    "contractName": "rocketDAOSecurityActions"
  },
  "display": {
    "formats": {
      "actionJoin()": { "intent": "Join security council", "fields": [] },
      "actionLeave()": { "intent": "Leave security council", "fields": [] },
      "actionRequestLeave()": { "intent": "Request to leave council", "fields": [] },
      "actionKick(address _memberAddress)": {
        "intent": "Kick security council member",
        "fields": [
          {
            "label": "Member",
            "format": "addressName",
            "params": { "types": ["eoa", "wallet"], "sources": ["local", "ens"] },
            "path": "#._memberAddress",
            "visible": "always"
          }
        ]
      },
      "actionKickMulti(address[] _memberAddresses)": {
        "intent": "Kick security council members",
        "fields": [
          {
            "label": "Members",
            "format": "addressName",
            "params": { "types": ["eoa", "wallet"], "sources": ["local", "ens"] },
            "path": "#._memberAddresses.[]",
            "visible": "always"
          }
        ]
      }
    }
  }
}

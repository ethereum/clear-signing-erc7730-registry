{
  "$schema": "../../specs/erc7730-v2.schema.json",
  "context": {
    "$id": "rocketMinipoolBondReducer",
    "contract": {
      "deployments": [
        { "chainId": 1, "address": "0xDe8Ab526b19FCA2D5a57c4A78b698041717BE591" },
        { "chainId": 560048, "address": "0xE04621683Cdf2437a759400FC3dA995a08D38C1b" }
      ]
    }
  },
  "metadata": {
    "owner": "Rocket Pool",
    "info": { "url": "https://rocketpool.net" },
    "contractName": "rocketMinipoolBondReducer"
  },
  "display": {
    "formats": {
      "beginReduceBondAmount(address _minipoolAddress, uint256 _newBondAmount)": {
        "intent": "Begin minipool bond reduction",
        "fields": [
          {
            "label": "Minipool",
            "format": "addressName",
            "params": { "types": ["contract"], "sources": ["local"] },
            "path": "#._minipoolAddress",
            "visible": "always"
          },
          { "label": "New bond amount", "format": "amount", "path": "#._newBondAmount", "visible": "always" }
        ]
      },
      "voteCancelReduction(address _minipoolAddress)": {
        "intent": "Vote to cancel bond reduction",
        "fields": [
          {
            "label": "Minipool",
            "format": "addressName",
            "params": { "types": ["contract"], "sources": ["local"] },
            "path": "#._minipoolAddress",
            "visible": "always"
          }
        ]
      }
    }
  }
}
